# SageMath 10.5 Code für Zeta-Regularisierung (Casimir-Analogie)
from sage.all import *

def casimir_regularization_demo():
    print("--- Demonstration: Zeta-Funktions-Regularisierung ---")
    print("Beim Casimir-Effekt müssen wir oft divergente Reihen summieren.")
    print("Klassisches Beispiel: 1 + 2 + 3 + ... (Summe der Moden in 1D)")
    
    # Die Riemannsche Zeta-Funktion zeta(s) = sum(1/n^s)
    # Für s = -1 ist das formal "1 + 2 + 3 + ..."
    s = var('s')
    zeta_func = zeta(s)
    
    # Berechnung des Wertes bei s = -1
    # Dies ist der berühmte Wert, der in der Stringtheorie und beim Casimir-Effekt genutzt wird.
    casimir_value_1d = zeta_func.subs(s=-1)
    
    print(f"\nDie Zeta-Funktion zeta(s) bei s = -1:")
    print(f"Formal: 'Summe n^1' = {casimir_value_1d}")
    
    # Ein weiteres Beispiel, das in 3D-Casimir-Rechnungen vorkommt (Summe n^3)
    # s = -3
    casimir_value_3d = zeta_func.subs(s=-3)
    print(f"\nDie Zeta-Funktion zeta(s) bei s = -3:")
    print(f"Formal: 'Summe n^3' = {casimir_value_3d}")
    
    print("\n--- Fibonacci-Bezug (Theoretisch) ---")
    print("In Quasikristallen (Fibonacci-Ketten) ist die Zustandsdichte rho(E)")
    print("nicht glatt, sondern fraktal. Die 'Spur' (Trace) im Spectral Action Principle")
    print("würde dann keine glatte Summe sein, sondern fraktale Skalierungsexponenten enthalten.")

# Ausführen
casimir_regularization_demo()